# Application
APP_NAME=Pose_API
APP_ENV=development
DEBUG=true

# JWT — set SECRET_KEY to a long random value in production
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=sqlite:///./pose.db

# CORS — comma-separated list of allowed origins (use * for development only)
# Example for production: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# ETL
ETL_BASE_URL=http://localhost:8001
ETL_API_KEY=your-etl-api-key
